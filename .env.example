# ─── Supabase ──────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://wlxolfkhkxembiuofmfa.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Anthropic (Claude API) ────────────────────────────────────────
ANTHROPIC_API_KEY=
# Coach-Modell — claude-sonnet-4-6 ist der Sweetspot für Coaching-Dialoge.
# Profilauswertung läuft auf claude-opus-4-7 (einmalig, mehr Tiefe).
CLAUDE_COACH_MODEL=claude-sonnet-4-6
CLAUDE_PROFILER_MODEL=claude-opus-4-7

# ─── OpenAI Whisper (optional — Audio-Upload-Transkription) ───────
# Wird genutzt für den Fallback "Audio-Datei hochladen" wenn ein User
# die Browser-Mikrofon-Permission nicht freischalten kann/will.
# Kosten: $0.006 / Audio-Minute. Ohne Key wird der Endpoint disabled,
# der Live-Mikro-Button funktioniert weiterhin normal.
OPENAI_API_KEY=

# ─── Stripe ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Preis-IDs aus dem Stripe-Dashboard (legt zwei Preise an: monatlich + jährlich)
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=

# ─── App ───────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
