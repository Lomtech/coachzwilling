# ─── Supabase ──────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://wlxolfkhkxembiuofmfa.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── LLM-Provider ──────────────────────────────────────────────────
# Wer macht die Claude-Calls?
#   anthropic  (default) — Anthropic Direct (USA-Hosting, kein AVV-by-default)
#   bedrock                — AWS Bedrock (eu-central-1, Frankfurt)
#   langdock               — Langdock (EU-Hosting, DSGVO, ISO 27001,
#                            SOC 2 Type II, AVV über Langdock-Account)
LLM_PROVIDER=anthropic

# ─── Anthropic Direct (LLM_PROVIDER=anthropic) ─────────────────────
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ─── Langdock (LLM_PROVIDER=langdock) ──────────────────────────────
# Workspace anlegen + API-Key generieren in den Langdock-Workspace-Settings.
# Siehe docs/LANGDOCK_SETUP.md für vollständige Schritt-für-Schritt-Anleitung.
LANGDOCK_API_KEY=
# Region: "eu" (Frankfurt, default) oder "us"
LANGDOCK_REGION=eu
# Optional: eigener Endpoint überschreiben (z. B. self-hosted Deployment)
# LANGDOCK_BASE_URL=https://api.langdock.com/anthropic/eu/v1

# ─── AWS Bedrock (LLM_PROVIDER=bedrock) ────────────────────────────
# AWS_REGION=eu-central-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ─── Modell-IDs (alle Provider) ────────────────────────────────────
# Coach-Modell — claude-sonnet-4-6 ist der Sweetspot für Coaching-Dialoge.
# Profilauswertung läuft auf claude-opus-4-7 (einmalig, mehr Tiefe).
# Memory-Extractor läuft auf claude-haiku-4-5 (schnell, billig).
#
# Langdock kann Workspace-spezifische Suffixe brauchen (z. B. "-default").
# Wenn die Default-Werte nicht funktionieren: Liste abrufen via
#   curl -H "Authorization: Bearer $LANGDOCK_API_KEY" \
#        https://api.langdock.com/anthropic/eu/v1/models
# und passende IDs hier setzen.
CLAUDE_COACH_MODEL=claude-sonnet-4-6
CLAUDE_PROFILER_MODEL=claude-opus-4-7
CLAUDE_MEMORY_MODEL=claude-haiku-4-5

# ─── Speech-to-Text ────────────────────────────────────────────────
# Server-side STT für Push-to-talk-Aufnahmen (MediaRecorder → Upload → Text).
# Funktioniert in jedem Browser inkl. Firefox und OpenAI Atlas.
#
# STT_PROVIDER=speechmatics  Speechmatics Batch — EU-Hosting (Frankfurt),
#                            ISO 27001, AVV, ~$0.005-0.008/min. EMPFEHLUNG
#                            für DSGVO-strikte Setups. Siehe docs/WHISPER_SETUP.md.
# STT_PROVIDER=openai        OpenAI Whisper direkt — US-Hosting, $0.006/min.
#                            Bewusst — bricht EU-Linie wenn alles andere
#                            über Langdock läuft.
# STT_PROVIDER=disabled      Feature aus.
#
# Auto-Detect: ohne explizites STT_PROVIDER wählt der Code den ersten
# Provider mit gesetztem Key (Speechmatics > OpenAI > disabled).
STT_PROVIDER=disabled

# Speechmatics (LLM-Provider EU-Setup empfohlen)
SPEECHMATICS_API_KEY=
# Region: eu1 (Frankfurt, default), eu2, us1, us2, au1
SPEECHMATICS_REGION=eu1
# operating_point: enhanced (besser, ~$0.008/min) oder standard (~$0.005/min)
SPEECHMATICS_OPERATING_POINT=enhanced

# OpenAI Whisper (US-Pfad)
OPENAI_API_KEY=
# OPENAI_TRANSCRIPTION_MODEL=whisper-1
# OPENAI_BASE_URL=https://api.openai.com/v1

# ─── Browser-Mikrofon (Web Speech API) ─────────────────────────────
# Web Speech API streamt Audio an den Browser-Hersteller (Chrome → Google,
# Safari → Apple, Edge → Microsoft) — KEIN AVV mit deinem Coaching-Service.
# Für DSGVO-strikte Setups deshalb deaktivieren, dann läuft nur noch der
# Server-STT-Pfad (Speechmatics).
#
# NEXT_PUBLIC_SPEECH_PROVIDER=browser   (default) Live-Mikro über Web Speech API
# NEXT_PUBLIC_SPEECH_PROVIDER=disabled  Live-Mikro aus — nur Server-STT-Aufnahme
NEXT_PUBLIC_SPEECH_PROVIDER=browser


# ─── Stripe ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Preis-IDs aus dem Stripe-Dashboard (legt zwei Preise an: monatlich + jährlich)
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=

# ─── App ───────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Follow-up-Emails (Resend) ─────────────────────────────────────
# Pflicht für Auto-Mails. Setup: resend.com → API-Key → deepling.com
# als Sending-Domain verifizieren (SPF + DKIM DNS-Records setzen).
# Ohne Key wird der Cron-Endpoint nur loggen, nicht senden.
RESEND_API_KEY=
EMAIL_FROM="Deepling <hello@deepling.com>"

# Vercel Cron Auth — wird auto-injected von Vercel als Authorization-Header.
# Lokal: beliebigen Random-String setzen; Vercel: in Project Settings
# unter "Cron Jobs" → "Secret" automatisch erstellt.
CRON_SECRET=

# Sign-Secret für Follow-up Email-Links (Click + Unsubscribe Tokens).
# Beliebiger Random-String, sollte aber stabil bleiben — sonst werden
# alle bestehenden Email-Links ungültig. Default-Fallback: SUPABASE_SERVICE_ROLE_KEY.
FOLLOWUP_SECRET=

